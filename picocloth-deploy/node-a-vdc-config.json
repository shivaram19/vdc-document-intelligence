{
  "version": 1,
  "agents": {
    "defaults": {
      "workspace": "/home/shivaramgoud/tinkering/tinkering-with-claws/picocloth/node-a/workspace",
      "restrict_to_workspace": false,
      "model_name": "grok-4.20-reasoning",
      "max_tokens": 32768,
      "max_tool_iterations": 15,
      "context_window": 2000000,
      "steering_mode": "one-at-a-time",
      "system_prompt": "You are Node-A, the Document Curiosity Brain of the Trelo Labs VDC Document Intelligence fleet.\n\nYour mission: Research, query, and analyze construction documents (drawings, specs, RFIs, submittals) for the DOWNTOWN OFFICE TOWER project.\n\n## Your Characters (Document Entities)\n- A-101 (Architectural Drawing Notes): Design Visionary - knows building parameters, finishes, thermal specs\n- FPS-211313 (Fire Protection Spec): Safety Guardian - knows sprinkler design, NFPA 13, hazard classifications\n- MECH-HVAC (Mechanical Spec): Climate Controller - knows setpoints, VAV units, ASHRAE 90.1\n- RFI-LOG (Question Keeper): Tracks all active contradictions and unresolved questions\n- STRUCT-CIP (Structural Spec): Structure Engineer - knows concrete mixes, rebar, ACI 318, fireproofing\n\n## Capabilities\n1. Multi-Document RAG: Ask natural language questions, get cited answers from documents\n2. Contradiction Detection: Find mismatches between drawings and specs\n3. Cross-Reference Analysis: Link related requirements across disciplines\n\n## Rules\n- Always cite your sources (document name, section, sheet)\n- When you find contradictions, flag them immediately to the fleet\n- Write durable facts to shared/project/facts/ when you learn something important\n- Use fleet_spawn_task to delegate execution tasks to Node-B\n- Before context compaction, your digital twin will preserve your document knowledge",
      "routing": {
        "enabled": true,
        "light_model": "grok-4.1-fast",
        "threshold": 0.35
      }
    }
  },
  "channel_list": {
    "pico": {
      "enabled": true,
      "type": "pico",
      "settings": {
        "ping_interval": 30,
        "read_timeout": 60,
        "write_timeout": 10,
        "max_connections": 100,
        "token": "YOUR_PICO_CHANNEL_TOKEN_HERE"
      }
    }
  },
  "model_list": [
    {
      "model_name": "grok-4.20-reasoning",
      "provider": "openai",
      "model": "grok-4.20-0309-reasoning",
      "api_base": "https://api.x.ai/v1",
      "api_keys": [
        "YOUR_XAI_API_KEY_HERE"
      ],
      "enabled": true
    },
    {
      "model_name": "grok-4.1-fast",
      "provider": "openai",
      "model": "grok-4-1-fast-non-reasoning",
      "api_base": "https://api.x.ai/v1",
      "api_keys": [
        "YOUR_XAI_API_KEY_HERE"
      ],
      "enabled": true
    }
  ],
  "gateway": {
    "host": "127.0.0.1",
    "port": 18790,
    "log_level": "info"
  },
  "heartbeat": {
    "enabled": true,
    "interval": 30
  },
  "hooks": {
    "enabled": true,
    "processes": {
      "langfuse_bridge": {
        "enabled": true,
        "priority": 1,
        "command": [
          "/home/shivaramgoud/tinkering/tinkering-with-claws/picocloth/.venv/bin/python3",
          "/home/shivaramgoud/tinkering/tinkering-with-claws/picocloth/hooks/langfuse_bridge.py"
        ],
        "env": {
          "FLEET_NODE_ID": "node-a",
          "LANGFUSE_HOST": "http://localhost:3000"
        },
        "observe": [
          "turn_start",
          "turn_end",
          "llm_request",
          "llm_response",
          "tool_exec_start",
          "tool_exec_end",
          "error",
          "subturn_spawn",
          "context_compress"
        ]
      },
      "digital_twin_guardian": {
        "enabled": true,
        "priority": 2,
        "command": [
          "/home/shivaramgoud/tinkering/tinkering-with-claws/picocloth/.venv/bin/python3",
          "/home/shivaramgoud/tinkering/tinkering-with-claws/picocloth/hooks/digital_twin_guardian.py"
        ],
        "env": {
          "FLEET_NODE_ID": "node-a",
          "PICOCLAW_HOOK_TWIN_DIR": "/home/shivaramgoud/tinkering/tinkering-with-claws/picocloth/shared/digital-twins/node-a",
          "PICOCLAW_HOOK_PROJECT_DIR": "/home/shivaramgoud/tinkering/tinkering-with-claws/picocloth/shared/project",
          "PICOCLAW_HOOK_MAX_FACTS": "8"
        },
        "observe": [
          "turn_start",
          "turn_end",
          "context_compress",
          "subturn_spawn"
        ]
      }
    }
  },
  "tools": {
    "web": {
      "enabled": true,
      "provider": "duckduckgo"
    },
    "mcp": {
      "enabled": true,
      "servers": {
        "fleet_server": {
          "enabled": true,
          "command": "python3",
          "args": [
            "/home/shivaramgoud/tinkering/tinkering-with-claws/picocloth/mcp-fleet-server/server.py"
          ],
          "env": {
            "FLEET_NODE_ID": "node-a",
            "FLEET_SHARED_DIR": "/home/shivaramgoud/tinkering/tinkering-with-claws/picocloth/shared"
          }
        }
      }
    }
  }
}
