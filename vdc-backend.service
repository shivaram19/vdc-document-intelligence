[Unit]
Description=VDC Document Intelligence Flask Backend
After=network.target

[Service]
Type=notify
User=www-data
Group=www-data
WorkingDirectory=/home/shivaramgoud/network-research-intiative-shivaram/vdc-document-intelligence/backend
Environment=&quot;PATH=/home/shivaramgoud/network-research-intiative-shivaram/vdc-document-intelligence/backend/venv/bin&quot;
ExecStart=/home/shivaramgoud/network-research-intiative-shivaram/vdc-document-intelligence/backend/venv/bin/gunicorn --workers 3 --bind 0.0.0.0:5001 --timeout 120 app:app
ExecReload=/bin/kill -s HUP $MAINPID
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target